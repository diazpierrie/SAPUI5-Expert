<mvc:View 
    controllerName="Invoices.invoices.controller.HelloPanel"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Panel headerText="{i18n>helloPanel}" class="sapUiResponsiveMargin" width="auto">
        <content>
            <Button id="helloDialogButton" 
                    icon="sap-icon://action" 
                    text="{i18n>helloDialogButton}" 
                    press=".onOpenDialog" 
                    class="sapUiSmallMarginEnd"/>
            <Button text="{i18n>showHelloButtonText}" press=".onShowHello" class="sapUiSmallMarginEnd"/>
            <Input value="{/recipient/name}" width="60%" valueLiveUpdate="true"></Input> 
            <Text text="Hello {/recipient/name}" class="sapUiSmallMargin boldElements"/>
        </content> 
    </Panel>
    <core:Fragment fragmentName="Invoices.invoices.view.Form01" type="XML"/>
</mvc:View>