<mvc:View 
    controllerName="Invoices.invoices.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Shell >
        <App >
            <pages>
                <Page title="{i18n>appTitle}">
                <headerContent>
                <Button id="helloDialogButtonHeader" 
                        icon="sap-icon://action"  
                        press=".onOpenDialogHeader" 
                        class="sapUiSmallMarginEnd"/>
                </headerContent>
                    <content>
                        <mvc:XMLView viewName="Invoices.invoices.view.helloPanel"/>
                        <mvc:XMLView viewName="Invoices.invoices.view.InvoicesList"/>
                    </content>
                </Page>
            </pages> 
        </App> 
    </Shell>
</mvc:View>